# =============================================================================
# Kulloo frontend — copy to .env.local for local overrides (not committed)
# =============================================================================

# -----------------------------------------------------------------------------
# Build-time (Vite) — only when you need it
# -----------------------------------------------------------------------------
# Use when the browser cannot use same-origin `/api` (no nginx/Caddy/Traefik
# proxy in front of the API). Set before `pnpm build`. No trailing slash.
#
# Example: https://kulloocall.example.com
#
# VITE_API_BASE_URL=

# -----------------------------------------------------------------------------
# Docker image (runtime — nginx in the provided Dockerfile)
# -----------------------------------------------------------------------------
# Where nginx forwards `/api/*` to your Kulloo API. Not used by `pnpm dev`.
# Full URL with scheme and host:port; no path.
#
# Default in Dockerfile: http://api:5000  (Compose service name `api`)
#
# API_UPSTREAM=http://api:5000
