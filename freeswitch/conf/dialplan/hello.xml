<include>
  <context name="mrf">
    <extension name="hello-call">
      <condition field="destination_number" expression="^(1000|hello)$">
        <action application="answer"/>
        <action application="sleep" data="500"/>
        <!-- Play a 1-second beep to confirm audio is working (image has no sound files) -->
        <action application="playback" data="tone_stream://%(1000,0,440)"/>
        <action application="set" data="recording_path=/recordings/${uuid}.wav"/>
        <action application="record_session" data="${recording_path}"/>
        <action application="sleep" data="20000"/>
        <action application="stop_record_session" data="${recording_path}"/>
        <!-- Notify Kulloo backend so it can persist recording metadata in MongoDB -->
        <action application="set" data="curl_timeout=5"/>
        <action application="curl" data="${kulloo_recording_webhook_url} post callUuid=${uuid}&amp;durationSec=20"/>
        <action application="hangup"/>
      </condition>
    </extension>
  </context>
</include>
