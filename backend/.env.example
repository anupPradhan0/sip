NODE_ENV=development
# Logging: debug|info|warn|error (default info in production, debug in development)
# LOG_LEVEL=info
# production logs are JSON lines unless LOG_FORMAT=pretty
# LOG_FORMAT=pretty
PORT=5000

# Redis (required): the API exits on startup if REDIS_URL is missing or Redis does not PING.
# Local: redis://localhost:6379  |  Docker Compose API service: redis://redis:6379
REDIS_URL=redis://localhost:6379
# REDIS_KEY_PREFIX=kulloo:
# REDIS_IDEMPOTENCY_TTL_SEC=86400
# REDIS_WEBHOOK_DEDUPE_TTL_SEC=172800
# Local dev: localhost. Docker/Dokploy: use Mongo service hostname or host IP — never localhost unless Mongo runs in that same container.
MONGODB_URI=mongodb://localhost:27017/sip-backend
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
PLIVO_AUTH_ID=
PLIVO_AUTH_TOKEN=
PLIVO_ANSWER_URL=
PLIVO_HANGUP_URL=
PUBLIC_BASE_URL=
FREESWITCH_SIP_URI=
# Production recommended:
# - backend container mounts the same volume as FreeSWITCH at /recordings
RECORDINGS_DIR=/recordings

# FreeSWITCH ESL Configuration
# Host where FreeSWITCH is running (use container name in Docker, localhost for local dev)
FREESWITCH_ESL_HOST=localhost
# ESL port (default: 8021)
FREESWITCH_ESL_PORT=8021
# ESL password (default: ClueCon)
FREESWITCH_ESL_PASSWORD=ClueCon
# Port for ESL outbound server (FreeSWITCH connects TO this port)
ESL_OUTBOUND_PORT=3200

ORPHAN_GRACE_MS=120000
ORPHAN_SWEEP_INTERVAL_MS=60000